    "happy-dom": "^20.10.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.0",
    "rollup-plugin-visualizer": "^5.14.0",
    "terser": "^5.39.0",
    "typescript": "^5.8.0",
    "unplugin-auto-import": "^19.0.0",
    "unplugin-vue-components": "^28.0.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.8",
    "vue-tsc": "^2.1.10"
  }
