{
  "name": "break",
  "version": "2.14.2",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run lint && npm run type-check && npm run validate:data && npm run test && npm run build-only && npm run audit:bundle:check && npm run validate:docs-build",
    "preview": "vite preview",
    "build-only": "vite build",
    "analyze": "ANALYZE=1 vite build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "validate:data": "node scripts/validate/schema.mjs && node scripts/validate/i18n-sync.mjs --strict && node scripts/validate/keywords.mjs && node scripts/validate/check-entity-relations.mjs && node scripts/validate/relations.mjs && node scripts/validate/business-scenes.mjs && node scripts/validate/require-references.mjs && node scripts/validate/docs-consistency.mjs",
    "validate:docs-build": "node scripts/validate/docs-build-sync.mjs",
    "audit:keywords": "node scripts/validate/keywords.mjs",
    "fix:keywords": "node scripts/validate/keywords.mjs --write",
    "list:keyword-batches": "node scripts/validate/keyword-batches.mjs",
    "audit:relations": "node scripts/validate/relations.mjs",
    "audit:references": "node scripts/validate/references.mjs",
    "audit:metrics": "node scripts/validate/metrics.mjs",
    "audit:bundle": "node scripts/validate/bundle-budget.mjs",
    "audit:bundle:check": "node scripts/validate/bundle-budget.mjs --check-only",
    "audit:maintenance": "npm run audit:references && npm run audit:relations && npm run audit:metrics && node scripts/validate/bundle-budget.mjs --no-fail && node scripts/validate/maintenance.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.9.0",
    "echarts": "^6.1.0",
    "element-plus": "^2.10.0",
    "fuse.js": "^7.4.2",
    "vue": "^3.5.0",
    "vue-i18n": "^11.4.4",
    "vue-router": "^4.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tsconfig/node18": "^18.2.2",
    "@types/node": "^22.15.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "happy-dom": "^20.10.2",
    "playwright": "^1.61.0",
    "prettier": "^3.5.0",
    "rollup-plugin-visualizer": "^5.14.0",
    "terser": "^5.39.0",
    "typescript": "^5.8.0",
    "unplugin-auto-import": "^19.0.0",
    "unplugin-vue-components": "^28.0.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue-tsc": "^2.1.10"
  }
}
